# Backend Configuration
NODE_ENV=production
PORT=3000

# Frontend URL (CORS)
FRONTEND_URL=https://clinostat.vercel.app

# Hardware Configuration
CLINOSTAT_WIFI_IP=192.168.1.100
CLINOSTAT_SERIAL_PORT=/dev/ttyUSB0
CLINOSTAT_BAUD_RATE=115200

# WebSocket Configuration
WS_PORT=3001
WS_ENABLE_SSL=true

# Logging
LOG_LEVEL=info
